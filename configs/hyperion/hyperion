#!/usr/bin/env nu
# Hyperion system utilities

# Boot routine - runs on system startup
def "main boot-routine" [] {
  let config_dir = ($env.HOME | path join ".config/hyperion")
  let store_file = ($config_dir | path join "store.json")
  
  # Ensure config directory exists
  mkdir $config_dir
  
  # Load or create store - ensure we always have a valid record
  mut store = if ($store_file | path exists) {
    try {
      open $store_file
    } catch {
      {}
    }
  } else {
    {}
  }
  
  # Ensure store is a record (in case file was corrupted)
  if ($store | describe | str starts-with "record") == false {
    $store = {}
  }
  
  # Show welcome on first boot
  if not ($store | get -o welcome_shown | default false) {
    print "First boot detected - launching Hyperion Welcome"
    
    # Launch quickshell in background
    let welcome_path = ($env.HOME | path join ".config/hyperion/hyperion-welcome/shell.qml")
    run-external "sh" "-c" $"setsid quickshell -p '($welcome_path)' >/dev/null 2>&1 &"
    
    # Update store to mark welcome as shown (merge, don't override)
    $store = ($store | merge { welcome_shown: true })
    $store | save -f $store_file
  }
}

# Launch the welcome screen
def "main welcome-screen" [] {
  print "Launching Hyperion Welcome"
  let welcome_path = ($env.HOME | path join ".config/hyperion/hyperion-welcome/shell.qml")
  run-external "quickshell" "-p" $welcome_path
}

# Main entry point
def main [] {
  print "Hyperion system utilities"
  print "Available commands:"
  print "  boot-routine    - Run boot initialization"
  print "  welcome-screen  - Launch the welcome screen"
}
